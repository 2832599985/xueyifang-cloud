# ==========================================
# xueyifang-cloud 生产环境配置
# 复制此文件为 .env 并填写实际值
# ==========================================

# ---------- 镜像标签 ----------
TAG=latest

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
MYSQL_DATABASE=xueyifang
MYSQL_APP_USERNAME=xueyifang
MYSQL_APP_PASSWORD=CHANGE_ME_APP_PASSWORD
MYSQL_PORT=3306

# ---------- Redis ----------
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_PORT=6379

# ---------- Nacos ----------
NACOS_PORT=8848
NACOS_USERNAME=nacos
NACOS_PASSWORD=CHANGE_ME_NACOS_PASSWORD
NACOS_AUTH_TOKEN=CHANGE_ME_NACOS_AUTH_TOKEN_32_CHARS_MIN
NACOS_AUTH_IDENTITY_KEY=nacos
NACOS_AUTH_IDENTITY_VALUE=CHANGE_ME_IDENTITY_VALUE
NACOS_NAMESPACE=

# ---------- JWT ----------
JWT_SECRET=CHANGE_ME_JWT_SECRET_AT_LEAST_32_BYTES

# ---------- Gateway ----------
GATEWAY_PORT=18080